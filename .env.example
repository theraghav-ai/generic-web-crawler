# Target website URL (required if not passed via CLI)
CRAWL_BASE_URL=https://www.example.com

# Crawl limits
CRAWL_MAX_DEPTH=2
CRAWL_MAX_PAGES=100

# Request behavior
CRAWL_REQUEST_DELAY=1.0
CRAWL_REQUEST_TIMEOUT=30
CRAWL_PAGE_LOAD_WAIT_MS=2000

# Content filtering
CRAWL_MIN_TEXT_LENGTH=80

# Feature toggles
CRAWL_USE_SITEMAP=true
CRAWL_EXPAND_DYNAMIC=true
CRAWL_IGNORE_ROBOTS=false
CRAWL_NO_PATH_FILTER=false

# Scope control (comma-separated, auto-derived from base URL if empty)
# CRAWL_ALLOWED_DOMAINS=
# CRAWL_ALLOWED_PATH_PREFIXES=
# SEED_URLS=

# Proxy and authentication
# CRAWL_PROXY_LIST=http://proxy1:8080,http://proxy2:8080
# CRAWL_COOKIE_FILE=cookies.json

# Checkpointing
CRAWL_CHECKPOINT_INTERVAL=10

# Logging
LOG_LEVEL=INFO
